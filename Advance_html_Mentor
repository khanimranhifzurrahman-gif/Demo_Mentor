<!DOCTYPE html>
<html>
<head>
<style>
table {
    width: 70%;
    border-collapse: collapse;
}

caption {
    font-size: 20px;
    font-weight: bold;
    margin: 10px;
}

th, td {
    border: 1px solid black;
    padding: 12px;
    text-align: center;
}

th {
    background-color: #f2f2f2;
}

tr:hover {
    background-color: #ddd;
}
</style>
</head>
<body>

<table>
    <caption>Employee Details</caption>

    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th colspan="2">Contact</th>
        </tr>
    </thead>

    <tbody>
        <tr>
            <td rowspan="2">101</td>
            <td>Imran</td>
            <td>Email</td>
            <td>imran@gmail.com</td>
        </tr>
        <tr>
            <td>Imran</td>
            <td>Phone</td>
            <td>9876543210</td>
        </tr>

        <tr>
            <td>102</td>
            <td>Amit</td>
            <td>Email</td>
            <td>amit@gmail.com</td>
        </tr>
    </tbody>

    <tfoot>
        <tr>
            <td colspan="4">Total Employees: 2</td>
        </tr>
    </tfoot>
</table>

</body>
</html>